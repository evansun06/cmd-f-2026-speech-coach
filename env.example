
ENVIRONMENT=development
DOMAIN_NAME=localhost
DJANGO_SETTINGS_MODULE=config.settings.dev

# Application database
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=db
DB_PORT=5432
DB_PUBLISHED_PORT=5433

# Frontend -> backend cross-origin auth
CORS_ALLOWED_ORIGINS=http://localhost:5173
CSRF_TRUSTED_ORIGINS=http://localhost:5173

# Django media storage
MEDIA_URL=/media/
MEDIA_ROOT=/app/media

# Redis + Celery + Flower
REDIS_PORT=6379
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
CELERY_WORKER_LOGLEVEL=info
CELERY_RESULT_EXPIRES=3600
FLOWER_PORT=5555
FLOWER_BASIC_AUTH=admin:admin

# pgAdmin
PGADMIN_PORT=5050
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=admin

# LLM
GEMINI_API_KEY=...
GEMINI_SUBAGENT_MODEL=gemini-2.0-flash
GEMINI_PRIMARY_MODEL=gemini-3.0-pro
GEMINI_SUBAGENT_TEMPERATURE=0.2
GEMINI_PRIMARY_TEMPERATURE=0.1
GEMINI_FLAGSHIP_FINAL_SYSTEM_PROMPT=You are the final speech coaching synthesis model.
GOOGLE_CLOUD_PROJECT=...
LLM_LEDGER_REDIS_URL=redis://redis:6379/0
LLM_LEDGER_REDIS_TTL_SECONDS=86400

